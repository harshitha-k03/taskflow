# ==========================
# Team Task Manager .gitignore
# ==========================

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment variables (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
out/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Cache
.npm
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
.vite/

# Editor directories & files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# TypeScript
*.tsbuildinfo

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files (extra safety)
*.env
!.env.example

# MongoDB local data (if running locally)
data/

# Test artifacts
junit.xml
test-results/

# Misc
*.local

.agents/
