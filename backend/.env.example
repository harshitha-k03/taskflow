NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/taskflow
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-this-in-production
REFRESH_TOKEN_EXPIRE=7d
FRONTEND_URL=http://localhost:5173

# AI Chatbot — Groq (Primary, get keys from console.groq.com)
GROQ_API_KEY_1=gsk_your_groq_key_1
GROQ_API_KEY_2=gsk_your_groq_key_2

# AI Chatbot — Gemini (Fallback, get keys from aistudio.google.com)
GEMINI_API_KEY_1=AIza_your_gemini_key_1
GEMINI_API_KEY_2=AIza_your_gemini_key_2
